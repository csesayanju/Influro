# Copy to .env.local and fill in from Supabase → Settings → API Keys
# URL: https://<project-ref>.supabase.co  (Project Settings → General → Reference ID)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (sb_publishable_...) or legacy anon JWT — safe for browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: canonical URL in Production (Vercel). Preview uses VERCEL_URL via next.config.
# NEXT_PUBLIC_SITE_URL=https://influro.vercel.app

# Secret key (sb_secret_...) or legacy service_role JWT — server-only, never commit
SUPABASE_SECRET_KEY=your-secret-key
